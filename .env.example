# OllamaPilot 配置文件示例
# 复制此文件为 .env 并根据需要填写配置

# ============================================
# Ollama 服务配置（必须）
# ============================================
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# 对话模型配置 (生成模型)
# ============================================
CHAT_MODEL=qwen3.5:4b
CHAT_TEMPERATURE=0.7
CHAT_NUM_CTX=8192
CHAT_NUM_PREDICT=2048

# ============================================
# Embedding 模型配置 (向量模型)
# ============================================
EMBEDDING_MODEL=qwen3-embedding:0.6b

# ============================================
# GraphRAG 配置
# ============================================
GRAPH_RAG_ENABLE_WORD_ALIGNER=true
GRAPH_RAG_FUZZY_THRESHOLD=0.75
GRAPH_RAG_KNOWLEDGE_BASE_DIR=./knowledge_base
GRAPH_RAG_PERSIST_DIR=./data/graphrag

# ============================================
# 系统配置
# ============================================
VERBOSE=true
DEFAULT_THREAD_ID=default
CLI_TIMEOUT=120

# Agent 递归限制
# 控制 Agent 最大迭代次数，防止无限循环
# 默认值 50，超过此次数会抛出异常
# 如果问题复杂需要更多迭代，可适当增大
RECURSION_LIMIT=50

# ============================================
# 搜索引擎配置（免费API优先策略）
# ============================================
# 
# 【配置说明】
# 1. 标记为【可选】的可以不配置，系统会使用免费备用引擎
# 2. 标记为【推荐】的建议配置，可提升搜索质量
# 3. 所有API均为国内可直接访问，无需翻墙
# 4. 配额用完后会自动降级到备用引擎
#

# ---- SearXNG 配置（推荐本地部署）----
# 【推荐】本地部署的聚合搜索引擎，无限额度
# 部署文档：https://github.com/searxng/searxng-docker
SEARXNG_URL=http://localhost:8080
SEARXNG_AUTO_START=true

# ---- GitHub API 配置（可选）----
# 【可选】代码搜索，500次/小时
# 申请地址：https://github.com/settings/tokens
# 不配置时会自动使用 Gitee（无限额度）
GITHUB_TOKEN=your_github_token_here

# ---- Serper.dev 配置（可选）----
# 【可选】Google搜索API，2500次/月
# 申请地址：https://serper.dev
SERPER_API_KEY=your_serper_key_here

# ---- Bing Search API 配置（可选）----
# 【可选】必应搜索API，1000次/月
# 申请地址：https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_API_KEY=your_bing_key_here

# ---- Brave Search API 配置（可选）----
# 【可选】Brave搜索API，2000次/月
# 申请地址：https://brave.com/search/api/
BRAVE_API_KEY=your_brave_key_here

# ============================================
# 配额管理配置
# ============================================
ENABLE_QUOTA_MANAGEMENT=true
QUOTA_WARNING_THRESHOLD=80
AUTO_FALLBACK=true

# ============================================
# 深度研究配置（Deep Research）
# ============================================
deep_research_max_iterations=6
deep_research_max_concurrent=5
deep_research_allow_clarification=true

# ============================================
# Tavily API 配置（深度研究可选）
# ============================================
# 【可选】Tavily搜索API，用于深度研究
# 免费额度：1000次/月
# 申请地址：https://tavily.com
TAVILY_API_KEY=your_tavily_key_here

# ============================================
# OpenAI API 配置（可选，用于深度研究）
# ============================================
# 【可选】OpenAI搜索功能
# 申请地址：https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# ============================================
# 其他可选API配置
# ============================================
# 【可选】Jina AI 搜索（免费额度）
JINA_API_KEY=your_jina_key_here

# 【可选】Exa.ai 搜索（免费额度）
EXA_API_KEY=your_exa_key_here
