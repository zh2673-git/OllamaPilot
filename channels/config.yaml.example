# ============================================
# OllamaPilot Channels 配置文件样本
# ============================================
#
# 使用说明:
#   1. 复制此文件为 config.yaml: cp config.yaml.example config.yaml
#   2. 修改 config.yaml 中的配置（填入你的真实凭证）
#   3. 运行: python -m channels.runner
#
# 注意: config.yaml 包含敏感信息，请勿提交到版本控制！

agent:
  model: "qwen3.5:4b"
  skills_dir: "./skills"
  verbose: true
  max_workers: 5

global:
  whitelist: []  # 空列表表示允许所有人使用
  admin_users: []
  max_message_length: 4000

channels:
  qq:
    enabled: false  # 设置为 true 启用 QQ Bot
    app_id: "你的AppID"
    app_secret: "你的AppSecret"
    token: "你的Token"
    sandbox: true  # true=沙箱环境, false=正式环境
    whitelist: []  # 空列表表示允许所有人使用
    at_only_in_group: true
    # QQ Bot v2 Intents 事件订阅
    # C2C_MESSAGE_CREATE: 单聊消息 (1<<25)
    # GROUP_AT_MESSAGE_CREATE: 群聊@消息 (1<<26)
    # DIRECT_MESSAGE_CREATE: 频道私信 (1<<30)
    intents:
      - "C2C_MESSAGE_CREATE"      # 单聊消息
      - "GROUP_AT_MESSAGE_CREATE" # 群聊@消息

  feishu:
    enabled: false
    app_id: "cli_xxxxxxxxxx"
    app_secret: "xxxxxxxxxx"
    encrypt_key: ""
    verification_token: ""
    whitelist: []
    at_only_in_group: true

  dingtalk:
    enabled: false
    app_key: "xxxxxxxxxx"
    app_secret: "xxxxxxxxxx"
    robot_code: ""
    agent_id: ""
    webhook_token: ""
    whitelist: []
    at_only_in_group: true

logging:
  level: "INFO"
  file: "logs/channels.log"
  max_bytes: 10485760
  backup_count: 5
